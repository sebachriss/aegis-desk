# DeepInfra API Key — https://deepinfra.com (requerido para workers y embeddings)
DEEPINFRA_API_KEY=tu_api_key_aqui

# Modelo de embeddings en DeepInfra (opcional; por defecto Qwen3-Embedding-8B)
# DEEPINFRA_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# Dimensión de los embeddings (1024 para Qwen3-Embedding-8B con MRL; 384 para all-MiniLM-L6-v2 local)
# EMBEDDING_DIMENSION=1024

# Groq API Key (opcional, recomendado para supervisor/crítico rápido) — https://console.groq.com
GROQ_API_KEY=tu_api_key_aqui

# Supabase — https://supabase.com
# Copiar URL y anon key desde Project Settings > API.
# Service key se usa para migraciones y operaciones admin (no la expongas).
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_KEY=<anon-public-key>
SUPABASE_SERVICE_KEY=<service-role-key>

# Postgres directo (Supabase Connection Pooler / Supavisor).
# Recomendado para conexiones desde local/Docker (resuelve IPv4).
# Si el password tiene $, @ o %, recomendamos percent-encodearlos en la URL
# (ej. $ -> %24, @ -> %40, % -> %25) para evitar que Docker Compose los
# interprete como variables de entorno.
DATABASE_URL=postgresql://postgres.<ref>:<password>@${HOST}.pooler.supabase.com:5432/postgres

# JWT Secret para auth (cambiar en producción; mínimo 32 caracteres)
JWT_SECRET=aegis-desk-demo-secret-change-in-production

# CORS (opcional; en producción restringir a dominios concretos)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LangSmith (opcional — tracing visual en https://smith.langchain.com)
# LANGSMITH_API_KEY=lsv2_pt_tu_key_aqui
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=aegis-desk
